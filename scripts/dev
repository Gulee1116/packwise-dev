#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_HOME="${REPO_ROOT}/.packwise-env"
JDK21_URL="https://api.adoptium.net/v3/binary/latest/21/ga/linux/x64/jdk/hotspot/normal/eclipse?project=jdk"
JDK17_URL="https://api.adoptium.net/v3/binary/latest/17/ga/linux/x64/jdk/hotspot/normal/eclipse?project=jdk"

usage() {
  cat <<'USAGE'
Usage: ./scripts/dev <command>

Commands:
  setup               Create/update the project-local Python venv, JDK 21, and client JDK 17.
  doctor              Verify the active local Python, Java, and cache paths.
  shell               Open a shell with the project-local environment active.
  test-python         Run Python agent tests.
  test-java-protocol  Run Java protocol tests without Minecraft/NeoForge.
  pr-fast-gate       Run the local PR gate: doctor, tests, connector builds, and diff whitespace check.
  build-forge         Run the full Forge connector Gradle build.
  build-neoforge      Run the full NeoForge connector Gradle build.
  smoke-forge-server  Run a headless Forge dedicated-server smoke test.
  atm9sky-headless    Run the external ATM9Sky headless validation lane.
  atm9sky-client-server
                      Run the external ATM9Sky client/server smoke lane.
  agent-http-e2e      Run a local agent HTTP integration lane.
  validate-dump       Validate a local runtime dump directory.
  import-dump         Validate and import a local runtime dump through AgentService.
  build-index         Build a normalized Packwise index from an installed instance.
  ask-local           Answer from a local instance and runtime dump.
  phase1-acceptance   Run the ATM9Sky Phase 1 acceptance report.
USAGE
}

require_linux_x64() {
  local os arch
  os="$(uname -s)"
  arch="$(uname -m)"
  if [ "${os}" != "Linux" ] || [ "${arch}" != "x86_64" ]; then
    echo "setup currently downloads Linux x64 JDKs. Install required JDKs under ${ENV_HOME}/ manually on this platform." >&2
    exit 1
  fi
}

download_file() {
  local url="$1"
  local dest="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -L --fail --retry 3 --retry-delay 2 -o "${dest}" "${url}"
  elif command -v wget >/dev/null 2>&1; then
    wget -O "${dest}" "${url}"
  else
    echo "curl or wget is required to download JDKs." >&2
    exit 1
  fi
}

setup_python() {
  mkdir -p "${ENV_HOME}/pip-cache" "${ENV_HOME}/pycache"
  export PIP_CACHE_DIR="${ENV_HOME}/pip-cache"
  export PYTHONPYCACHEPREFIX="${ENV_HOME}/pycache"
  if [ ! -x "${ENV_HOME}/python/bin/python" ]; then
    python3 -m venv "${ENV_HOME}/python"
  fi
  # shellcheck source=/dev/null
  source "${ENV_HOME}/python/bin/activate"
  python -m pip install --upgrade pip
}

setup_jdk() {
  local major="$1"
  local install_dir="$2"
  local archive_name="$3"
  local url="$4"

  if [ -x "${install_dir}/bin/java" ] && "${install_dir}/bin/java" -version 2>&1 | grep -q "version \"${major}"; then
    return
  fi

  require_linux_x64
  local extract_dir="${ENV_HOME}/jdk${major}-extract"
  mkdir -p "${ENV_HOME}/cache" "${extract_dir}"
  rm -rf "${install_dir}" "${extract_dir}"
  mkdir -p "${extract_dir}"

  local archive="${ENV_HOME}/cache/${archive_name}"
  download_file "${url}" "${archive}"
  tar -xzf "${archive}" -C "${extract_dir}"

  local extracted
  extracted="$(find "${extract_dir}" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
  if [ -z "${extracted}" ]; then
    echo "JDK archive did not contain an extracted directory." >&2
    exit 1
  fi

  mv "${extracted}" "${install_dir}"
  rm -rf "${extract_dir}"
}

setup_jdks() {
  setup_jdk 21 "${ENV_HOME}/jdk" "temurin-jdk21-linux-x64.tar.gz" "${JDK21_URL}"
  setup_jdk 17 "${ENV_HOME}/jdk17" "temurin-jdk17-linux-x64.tar.gz" "${JDK17_URL}"
}

activate_env() {
  # shellcheck source=env.sh
  source "${SCRIPT_DIR}/env.sh"
}

assert_local_env() {
  activate_env

  if [ "${JAVA_HOME:-}" != "${ENV_HOME}/jdk" ]; then
    echo "JAVA_HOME must be ${ENV_HOME}/jdk, got ${JAVA_HOME:-<unset>}." >&2
    exit 1
  fi
  if [ "${GRADLE_USER_HOME:-}" != "${ENV_HOME}/gradle" ]; then
    echo "GRADLE_USER_HOME must be ${ENV_HOME}/gradle, got ${GRADLE_USER_HOME:-<unset>}." >&2
    exit 1
  fi
  if ! java -version 2>&1 | grep -q 'version "21'; then
    echo "Java 21 is required." >&2
    java -version >&2 || true
    exit 1
  fi
  if ! javac -version 2>&1 | grep -q '^javac 21'; then
    echo "javac 21 is required." >&2
    javac -version >&2 || true
    exit 1
  fi
}

cmd_setup() {
  mkdir -p "${ENV_HOME}/gradle"
  setup_python
  setup_jdks
  assert_local_env
  doctor
}

doctor() {
  printf 'repo: %s\n' "${PACKWISE_REPO_ROOT}"
  printf 'env: %s\n' "${PACKWISE_ENV_HOME}"
  printf 'python: '
  python --version
  printf 'pip: '
  pip --version
  printf 'java: '
  java -version 2>&1 | head -n 1
  printf 'javac: '
  javac -version
  printf 'client-java17: '
  if [ -x "${ENV_HOME}/jdk17/bin/java" ]; then
    "${ENV_HOME}/jdk17/bin/java" -version 2>&1 | head -n 1
  else
    printf '<missing: run ./scripts/dev setup>\n'
  fi
  printf 'JAVA_HOME=%s\n' "${JAVA_HOME:-}"
  printf 'GRADLE_USER_HOME=%s\n' "${GRADLE_USER_HOME:-}"
  printf 'PIP_CACHE_DIR=%s\n' "${PIP_CACHE_DIR:-}"
  printf 'PYTHONPYCACHEPREFIX=%s\n' "${PYTHONPYCACHEPREFIX:-}"
  printf 'PYTHONPATH=%s\n' "${PYTHONPATH:-}"
}

cmd_test_python() {
  assert_local_env
  cd "${REPO_ROOT}/apps/agent"
  python -m unittest discover -s tests
}

cmd_test_java_protocol() {
  assert_local_env
  cd "${REPO_ROOT}"
  local out="connectors/neoforge/build/protocol-test-classes"
  rm -rf "${out}"
  mkdir -p "${out}"

  find connectors/common/src/main/java/dev/packwise/connector/protocol -name '*.java' -print > "${ENV_HOME}/protocol-sources.txt"
  find connectors/common/src/test/java/dev/packwise/connector/protocol -name '*.java' -print >> "${ENV_HOME}/protocol-sources.txt"
  printf '%s\n' connectors/forge/src/main/java/dev/packwise/connector/forge/ForgePackMetadata.java >> "${ENV_HOME}/protocol-sources.txt"
  printf '%s\n' connectors/forge/src/test/java/dev/packwise/connector/forge/ForgePackMetadataTest.java >> "${ENV_HOME}/protocol-sources.txt"
  printf '%s\n' connectors/neoforge/src/main/java/dev/packwise/connector/neoforge/NeoForgeModSnapshots.java >> "${ENV_HOME}/protocol-sources.txt"
  printf '%s\n' connectors/neoforge/src/test/java/dev/packwise/connector/neoforge/NeoForgeModSnapshotsTest.java >> "${ENV_HOME}/protocol-sources.txt"

  javac -encoding UTF-8 -d "${out}" @"${ENV_HOME}/protocol-sources.txt"
  java -cp "${out}" dev.packwise.connector.protocol.JsonTextTest
  java -cp "${out}" dev.packwise.connector.protocol.ProtocolCodecTest
  java -cp "${out}" dev.packwise.connector.protocol.RuntimeDumpManifestTest
  java -cp "${out}" dev.packwise.connector.protocol.ModsSectionDumperTest
  java -cp "${out}" dev.packwise.connector.protocol.NdjsonSectionDumperTest
  java -cp "${out}" dev.packwise.connector.protocol.CommandResponseTest
  java -cp "${out}" dev.packwise.connector.protocol.QueryAskTest
  java -cp "${out}" dev.packwise.connector.protocol.AgentAnswerTest
  java -cp "${out}" dev.packwise.connector.protocol.AgentHttpClientTest
  java -cp "${out}" dev.packwise.connector.protocol.RuntimeDumpUploaderTest
  java -cp "${out}" dev.packwise.connector.protocol.RuntimeDumpFileWriterTest
  java -cp "${out}" dev.packwise.connector.forge.ForgePackMetadataTest
  java -cp "${out}" dev.packwise.connector.neoforge.NeoForgeModSnapshotsTest
}

cmd_pr_fast_gate() {
  assert_local_env
  cd "${REPO_ROOT}"
  doctor
  cmd_test_python
  cmd_test_java_protocol
  cmd_build_forge
  cmd_build_neoforge
  cd "${REPO_ROOT}"
  git diff --check
  git diff --cached --check
}

cmd_build_forge() {
  assert_local_env
  cd "${REPO_ROOT}/connectors/forge"
  ./gradlew build
}

cmd_build_neoforge() {
  assert_local_env
  cd "${REPO_ROOT}/connectors/neoforge"
  ./gradlew build
}

cmd_phase1_acceptance() {
  assert_local_env
  cd "${REPO_ROOT}"
  python -m packwise_agent phase1-acceptance "$@"
}

cmd_import_dump() {
  assert_local_env
  cd "${REPO_ROOT}"
  python -m packwise_agent import-dump "$@"
}

cmd_validate_dump() {
  assert_local_env
  cd "${REPO_ROOT}"
  python -m packwise_agent validate-dump "$@"
}

cmd_build_index() {
  assert_local_env
  cd "${REPO_ROOT}"
  python -m packwise_agent build-index "$@"
}

cmd_ask_local() {
  assert_local_env
  cd "${REPO_ROOT}"
  python -m packwise_agent ask-local "$@"
}

cmd_smoke_forge_server() {
  assert_local_env
  cd "${REPO_ROOT}"
  "${REPO_ROOT}/scripts/forge-server-smoke" "$@"
}

cmd_atm9sky_headless() {
  assert_local_env
  cd "${REPO_ROOT}"
  "${REPO_ROOT}/scripts/atm9sky-headless" "$@"
}

cmd_atm9sky_client_server() {
  assert_local_env
  cd "${REPO_ROOT}"
  "${REPO_ROOT}/scripts/atm9sky-client-server" "$@"
}

cmd_agent_http_e2e() {
  assert_local_env
  cd "${REPO_ROOT}"
  "${REPO_ROOT}/scripts/agent-http-e2e" "$@"
}

command="${1:-}"
case "${command}" in
  setup)
    cmd_setup
    ;;
  doctor)
    assert_local_env
    doctor
    ;;
  shell)
    assert_local_env
    cd "${REPO_ROOT}"
    exec "${SHELL:-/bin/bash}"
    ;;
  test-python)
    cmd_test_python
    ;;
  test-java-protocol)
    cmd_test_java_protocol
    ;;
  pr-fast-gate)
    cmd_pr_fast_gate
    ;;
  build-forge)
    cmd_build_forge
    ;;
  build-neoforge)
    cmd_build_neoforge
    ;;
  smoke-forge-server)
    shift
    cmd_smoke_forge_server "$@"
    ;;
  atm9sky-headless)
    shift
    cmd_atm9sky_headless "$@"
    ;;
  atm9sky-client-server)
    shift
    cmd_atm9sky_client_server "$@"
    ;;
  agent-http-e2e)
    shift
    cmd_agent_http_e2e "$@"
    ;;
  import-dump)
    shift
    cmd_import_dump "$@"
    ;;
  validate-dump)
    shift
    cmd_validate_dump "$@"
    ;;
  build-index)
    shift
    cmd_build_index "$@"
    ;;
  ask-local)
    shift
    cmd_ask_local "$@"
    ;;
  phase1-acceptance)
    shift
    cmd_phase1_acceptance "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: ${command}" >&2
    usage >&2
    exit 2
    ;;
esac
